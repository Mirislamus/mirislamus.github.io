---
import Layout from '@layouts/Layout.astro';
import { Approach, Hero, Skills, Career, Projects, Reviews } from '@widgets/components';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'uz' } },
    { params: { lang: 'ru' } }
  ];
}
---

<Layout>
  <Hero client:load />
  <Approach client:visible />
  <Career client:visible />
  <Projects client:visible />
  <Skills client:visible />
  <Reviews client:visible />
</Layout>

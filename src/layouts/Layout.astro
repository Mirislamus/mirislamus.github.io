---
import type { Locale } from '@typings/global';
import '@styles/global.scss';
import Head from '@layouts/Head.astro';
import { Header, Footer } from '@widgets/components';
import { Toaster } from 'sonner';
import { localeAtom } from '@shared/stores';

const locale = Astro.currentLocale as Locale;

localeAtom.set(locale);
---

<!doctype html>
<html lang={locale}>
  <Head locale={locale} />
  <body>
    <script>
      import { initThemeStore } from '@utils/theme';
      initThemeStore();
    </script>
    <Header client:visible />
    <main>
      <slot />
    </main>
    <Toaster
      position="bottom-left"
      duration={5000}
      expand={false}
      visibleToasts={1}
      toastOptions={{
        unstyled: true,
        classNames: {
          toast: 'toast',
          title: 'toast__title',
          description: 'toast__description',
          actionButton: 'toast__action-button',
          cancelButton: 'toast__cancel-button',
          closeButton: 'toast__close-button',
        },
      }}
      client:load
    />
    <Footer client:visible />
  </body>
</html>
